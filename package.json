{
  "name": "iqbe",
  "version": "2.0.0",
  "description": "A powerful tool to enhance your quiz skills more fun and effective. ",
  "workspaces": [
    "packages/frontend",
    "packages/backend",
    "packages/api"
  ],
  "private": true,
  "scripts": {
    "build": "env-cmd -f .env node ./scripts/build.mjs",
    "start": "env-cmd -f .env node ./packages/backend/dist/index.js",
    "clean": "node ./scripts/clean.mjs",
    "dev":   "env-cmd -f .env node ./scripts/dev.mjs",
    "api":   "npm run build -w packages/api",
    "migrate:create": "env-cmd -f .env npm run migrate:create -w packages/backend",
    "migrate:exe":    "env-cmd -f .env npm run migrate:exe -w packages/backend",
    "migrate:dev":    "npm run migrate:exe",
    "migrate:status": "env-cmd -f .env npm run migrate:status -w packages/backend",
    "migrate:reset":  "env-cmd -f .env npm run migrate:reset -w packages/backend"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/woodnext/iqbe-dev.git"
  },
  "author": "woodnext",
  "license": "ISC",
  "dependencies": {
    "ps-tree": "^1.2.0"
  }
}
